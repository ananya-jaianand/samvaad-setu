# Samvaad-Setu Backend Configuration
# Copy this file and fill in your values.

# Backend base URL (FastAPI)
BACKEND_URL=http://localhost:8000

# WebSocket URL
WS_URL=ws://localhost:8000/ws

# Default district for new sessions
DEFAULT_DISTRICT=bangalore_urban

# Default language code (kn = Kannada, hi = Hindi, en = English)
DEFAULT_LANGUAGE=kn
