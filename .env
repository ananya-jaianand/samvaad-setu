# Samvaad-Setu Backend Environment Variables

# ============================================
# API Keys (Required for production mode)
# ============================================

# LiveKit (For real-time voice agent)
LIVEKIT_URL=wss://samvaad-setu-csixjpi4.livekit.cloud
LIVEKIT_API_KEY=APISmmsGZHwR7w8
LIVEKIT_API_SECRET=zd0Ab7RzO0fblK8hWPuDnebpWDYT2noO7CaUpDZOiy1

# Anthropic Claude API Key (Optional - for Claude-based NLU)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini API Key (Recommended - for Gemini-based NLU)
GEMINI_API_KEY=AIzaSyBmF0deFEWv0Lv3HkYuXsPrd9jmUG4yjo8

# Sarvam AI API Key (for Indian language ASR/TTS)
SARVAM_API_KEY=sk_p5xi52la_zBWE72pjlPcwmACZFWkJuklK

# AI4Bharat API Key (for Indian language models)
AI4BHARAT_API_KEY=

# ============================================
# Application Configuration
# ============================================

# Environment mode: "mock" or "production"
# Use "mock" for development without API keys
ENVIRONMENT=mock

# Redis connection URL
REDIS_URL=redis://localhost:6379

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8081

# Session timeout in minutes
MAX_SESSION_MINUTES=30

# ============================================
# Escalation Thresholds
# ============================================

# ASR confidence threshold (0.0-1.0)
ASR_CONFIDENCE_THRESHOLD=0.65

# Intent entropy threshold (0.0-1.0)
INTENT_ENTROPY_THRESHOLD=0.45

# Distress score threshold (0.0-1.0)
DISTRESS_SCORE_THRESHOLD=0.70

# Maximum clarification attempts before escalation
MAX_CLARIFICATION_TURNS=3

# ============================================
# Model Configuration
# ============================================

# Claude model version
CLAUDE_MODEL=claude-sonnet-4-20250514

# Sarvam ASR model
SARVAM_ASR_MODEL=saarika:v2

# Sarvam TTS model
SARVAM_TTS_MODEL=bulbul:v1
